<Page x:Class="AppSpotifyWPF.Screens.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:AppSpotifyWPF.Screens"
      Title="Admin Dashboard">

    <Border Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,25">
        <StackPanel>
            <UniformGrid Columns="3" Rows="2"
                         Margin="0,10,0,0"
                         HorizontalAlignment="Center"
                         Width="700">

                <Button x:Name="userManagementButton" Margin="10" Padding="20" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" Click="userManagementButton_Click" HorizontalAlignment="Left" Width="155">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE716;" FontSize="36" HorizontalAlignment="Center"/>
                        <TextBlock Text="Users" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Users management" FontSize="12" Foreground="Gray" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="songManagementButton" Margin="10" Padding="20" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" Click="songManagementButton_Click" HorizontalAlignment="Left" Width="155">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE189;" FontSize="36" HorizontalAlignment="Center"/>
                        <TextBlock Text="Songs" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Songs management" FontSize="12" Foreground="Gray" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="playlistManagementButton" Margin="10" Padding="20" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" Click="playlistManagementButton_Click" HorizontalAlignment="Left" Width="155">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE179;" FontSize="36" HorizontalAlignment="Center"/>
                        <TextBlock Text="Playlists" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Playlists management" FontSize="12" Foreground="Gray" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="roleManagementButton" Margin="10" Padding="20" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" Click="roleManagementButton_Click" HorizontalAlignment="Left" Width="155">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8D7;" FontSize="36" HorizontalAlignment="Center"/>
                        <TextBlock Text="Roles" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Manage Roles" FontSize="12" Foreground="Gray" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="permissionManagementButton" Margin="10" Padding="20" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" Click="permissionManagementButton_Click" HorizontalAlignment="Left" Width="155">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE72D;" FontSize="36" HorizontalAlignment="Center"/>
                        <TextBlock Text="Permissions" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Access Control" FontSize="12" Foreground="Gray" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="assignmentManagementButton" Margin="10" Padding="20" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" Click="assignmentManagementButton_Click" HorizontalAlignment="Left" Width="155">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE1E2;" FontSize="36" HorizontalAlignment="Center"/>
                        <TextBlock Text="Assignments" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="User/Role Links" FontSize="12" Foreground="Gray" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </UniformGrid>
        </StackPanel>
    </Border>

</Page>