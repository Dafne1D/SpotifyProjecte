<Page x:Class="AppSpotifyWPF.Screens.Songs.PagCreateSong"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="PagCreateSong">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#F5F6FA">
        <StackPanel Margin="40">
            <Button
        Margin="0 0 0 5"
        Background="Transparent"
        Foreground="Gray"
        BorderBrush="Transparent"
        BorderThickness="1"
        Click="BackToHome_Click"
        HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                   Text="&#xE76B;"
                   FontSize="16"
                   Margin="0 0 10 0"/>
                    <TextBlock Text="Back to Home"
                   FontWeight="Bold"/>
                </StackPanel>
            </Button>
            <TextBlock Text="Create Song" FontSize="22" FontWeight="Bold" Margin="0 0 70 30"/>

            <TextBlock Text="Song Name" FontWeight="Bold" Margin="0,0,0,2"/>
            <TextBox x:Name ="txtName" Margin="0,0,0,10" Height="20"/>

            <TextBlock Text="Artist" FontWeight="Bold" Margin="0,0,0,2" Height="18"/>
            <TextBox x:Name="txtArtist" Margin="0,0,0,10" Height="20"/>

            <TextBlock Text="Album" FontWeight="Bold" Margin="0,0,0,2"/>
            <TextBox x:Name="txtAlbum" Margin="0,0,0,10"  Height="20"/>

            <TextBlock Text="Duration" FontWeight="Bold" Margin="0,0,0,2"/>
            <TextBox x:Name="txtDuration" Margin="0,0,0,10" Height="20"/>
            
            <TextBlock Text="Genre" FontWeight="Bold" Margin="0,0,0,2"/>
            <TextBox x:Name="txtGenre" Margin="0,0,0,10" Height="20"/>

            <TextBlock Text="URL of the Cover" FontWeight="Bold" Margin="0,0,0,2"/>
            <TextBox x:Name="txtImgCover" Margin="0,0,0,10" Height="20"/>

            <Button Content="CREATE" Click="CreateSong_Click" Background="#4CAF50" Foreground="White" Height="35" Margin="0,0,0,20"/>

        </StackPanel>
    </ScrollViewer>
</Page>
