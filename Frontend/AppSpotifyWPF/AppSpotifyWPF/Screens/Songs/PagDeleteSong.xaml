<Page x:Class="AppSpotifyWPF.Screens.Songs.PagDeleteSong"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="PagReadUser"
      Background="#F5F6FA">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40">
            <Button
                Margin="0 0 0 5"
                Background="Transparent"
                Foreground="Gray"
                BorderBrush="Transparent"
                BorderThickness="1"
                Click="BackToHome_Click"
                HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                   Text="&#xE76B;"
                   FontSize="16"
                   Margin="0 0 10 0"/>
                    <TextBlock Text="Back to Home"
                   FontWeight="Bold"/>
                </StackPanel>
            </Button>

            <TextBlock Text="Delete song" FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>

            <!-- Search bar -->
            <DockPanel Margin="0,0,0,30">
                <TextBox x:Name="txtSearch" Width="400" Height="35"
                         Text=""
                         HorizontalContentAlignment="Left"
                         VerticalContentAlignment="Center"/>
            </DockPanel>

            <WrapPanel x:Name="SongsWrap"
                       HorizontalAlignment="Left"
                       Margin="0,0,0,20"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,20">

                <Button Content="SEARCH"
                    Background="ForestGreen"
                    Foreground="White"
                    Width="150"
                    Height="35"
                    Click="LoadSongs_Click"
                    Margin="0,0,100,0"
                />

                <Button Content="DELETE"
                    Background="Red"
                    Foreground="White"
                    Width="150"
                    Height="35"
                    Click="DeleteSong_Click"
                />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
