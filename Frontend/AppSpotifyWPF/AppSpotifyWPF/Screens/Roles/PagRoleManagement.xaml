<Page x:Class="AppSpotifyWPF.PagRoleManagement"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Role Management" Background="White">

    <ScrollViewer>
        <StackPanel Margin="30">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Button Content="&lt; Back to Home" Click="OnBackClicked" HorizontalAlignment="Left" Background="Transparent" BorderBrush="Transparent"/>
                    <Label Content="Role Management" FontSize="32" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="+" Background="Green" Foreground="White" Width="40" Height="40" Margin="5" Click="OnCreateClicked"/>
                    <Button Content="👁" Width="40" Height="40" Margin="5" Click="OnViewClicked"/>
                    <Button Content="✎" Width="40" Height="40" Margin="5" Click="OnUpdateClicked"/>
                    <Button Content="🗑" Background="Red" Foreground="White" Width="40" Height="40" Margin="5" Click="OnDeleteClicked"/>
                </StackPanel>
            </Grid>

            <TextBox x:Name="SearchEntry" Margin="0,20" Width="400" HorizontalAlignment="Center" />
            <Button Content="Load" Background="LightGreen" Width="150" HorizontalAlignment="Center" Click="OnLoadClicked"/>

            <WrapPanel x:Name="RolesContainer" HorizontalAlignment="Center" Margin="0,20"/>
        </StackPanel>
    </ScrollViewer>
</Page>