<Page x:Class="AppSpotifyWPF.Screens.PagUserRoleAssignment"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="User Role Assignment" Background="White">

    <StackPanel Margin="30">
        <Button Content="&lt; Back" Click="OnBackClicked" HorizontalAlignment="Left" Background="Transparent" BorderBrush="Transparent"/>
        <Label Content="Assign Roles to Users" FontSize="28" FontWeight="Bold" Margin="0,0,0,20"/>

        <Border BorderBrush="Gray" BorderThickness="1" Padding="20" CornerRadius="10">
            <StackPanel>
                <Label Content="Select User:" Margin="0,0,0,5"/>
                <ComboBox x:Name="UserCombo" Width="300" HorizontalAlignment="Left" Margin="0,0,0,15"/>

                <Label Content="Select Role:" Margin="0,0,0,5"/>
                <ComboBox x:Name="RoleCombo" Width="300" HorizontalAlignment="Left" Margin="0,0,0,15"/>

                <Button Content="Assign Role" Width="150" Margin="0,10,0,0" Background="Blue" Foreground="White" Click="OnAssignClicked"/>
            </StackPanel>
        </Border>
    </StackPanel>
</Page>