<Page x:Class="AppSpotifyWPF.Screens.PagUserRoleAssignment"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="User Role Assignment"
      Background="#F5F6FA">

    <StackPanel Margin="40">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">

                <Button Background="Transparent"
                        BorderBrush="Transparent"
                        Click="OnBackClicked"
                        HorizontalAlignment="Left">

                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   Text="&#xE76B;"
                                   FontSize="16"
                                   Margin="0 0 10 0"/>
                        <TextBlock Text="Back"
                                   FontWeight="Bold"/>
                    </StackPanel>

                </Button>

                <TextBlock Text="Assign Roles to Users"
                           FontSize="28"
                           FontWeight="Bold"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        Grid.Column="1"
                        HorizontalAlignment="Right">

                <Button Margin="10 0"
                        Padding="10"
                        Background="LimeGreen"
                        BorderBrush="DarkGreen"
                        Click="OnCreateClicked">

                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               Text="&#xE710;"
                               FontSize="18"/>
                </Button>

                <Button Margin="10 0"
                        Padding="10"
                        Background="White"
                        BorderBrush="#E0E0E0"
                        Click="OnViewClicked">

                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               Text="&#xE7B3;"
                               FontSize="18"/>
                </Button>

                <Button Margin="10 0"
                        Padding="10"
                        Background="White"
                        BorderBrush="#E0E0E0"
                        Click="OnEditClicked">

                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               Text="&#xE70F;"
                               FontSize="18"/>
                </Button>

                <Button Margin="10 0"
                        Padding="10"
                        Background="Red"
                        BorderBrush="DarkRed"
                        Click="OnDeleteClicked">

                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               Text="&#xE74D;"
                               FontSize="18"/>
                </Button>

            </StackPanel>

        </Grid>

        <Border BorderBrush="Gray"
                BorderThickness="1"
                Padding="20"
                CornerRadius="10"
                Margin="0,20">

            <StackPanel>

                <Label Content="Select User:"/>
                <ComboBox x:Name="UserCombo"
                          Width="300"
                          Margin="0,0,0,15"/>

                <Label Content="Select Role:"/>
                <ComboBox x:Name="RoleCombo"
                          Width="300"
                          Margin="0,0,0,15"/>

                <Button Content="Assign Role"
                        Width="150"
                        Background="Blue"
                        Foreground="White"
                        Click="OnAssignClicked"/>

            </StackPanel>

        </Border>

    </StackPanel>

</Page>