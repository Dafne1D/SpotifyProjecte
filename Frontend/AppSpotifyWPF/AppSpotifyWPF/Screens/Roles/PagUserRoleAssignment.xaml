<Page x:Class="AppSpotifyWPF.Screens.PagUserRoleAssignment"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="User Role Assignment"
      Background="#F5F6FA">

    <StackPanel Margin="40">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Margin="0 0 0 0">

                <Button
                    Margin="0 0 0 5"
                    Background="Transparent"
                    Foreground="Gray"
                    BorderBrush="Transparent"
                    BorderThickness="1"
                    Click="BackToHome_Click"
                    HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                               Text="&#xE76B;"
                               FontSize="16"
                               Margin="0 0 10 0"/>
                        <TextBlock Text="Back to Home"
                               FontWeight="Bold"/>
                    </StackPanel>
                </Button>

                <TextBlock Text="Assign Roles"
                           FontSize="28"
                           FontWeight="Bold"/>
            </StackPanel>

        </Grid>

        <Border BorderBrush="Gray"
                BorderThickness="1"
                Padding="20"
                CornerRadius="10"
                Margin="0,20">

            <StackPanel>

                <Label Content="Select User:"/>
                <ComboBox x:Name="UserCombo"
                          Width="300"
                          Margin="0,0,0,15"/>

                <Label Content="Select Role:"/>
                <ComboBox x:Name="RoleCombo"
                          Width="300"
                          Margin="0,0,0,15"/>

                <Button Content="Assign Role"
                        Width="150"
                        Background="#1a9e44"
                        Foreground="Black"
                        Click="OnAssignClicked"/>

            </StackPanel>

        </Border>

    </StackPanel>

</Page>