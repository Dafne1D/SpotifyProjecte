<Page x:Class="AppSpotifyWPF.Screens.PagPermissionManagement"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Permission Management"
      Background="#F5F6FA">

    <ScrollViewer>
        <StackPanel Margin="40">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Button Background="Transparent"
                            BorderBrush="Transparent"
                            Click="OnBackClicked"
                            HorizontalAlignment="Left">

                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE76B;"
                                       FontSize="16"
                                       Margin="0 0 10 0"/>
                            <TextBlock Text="Back to Home"
                                       FontWeight="Bold"/>
                        </StackPanel>

                    </Button>

                    <TextBlock Text="Permission Management"
                               FontSize="28"
                               FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            Grid.Column="1"
                            HorizontalAlignment="Right">

                    <Button Margin="10 0"
                            Padding="10"
                            Background="LimeGreen"
                            Foreground="DarkGreen"
                            BorderBrush="DarkGreen"
                            BorderThickness="1"
                            Click="OnCreateClicked">

                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   Text="&#xE710;"
                                   FontSize="18"/>
                    </Button>

                    <Button Margin="10 0"
                            Padding="10"
                            Background="White"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1"
                            Click="OnViewClicked">

                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   Text="&#xE7B3;"
                                   FontSize="18"/>
                    </Button>

                    <Button Margin="10 0"
                            Padding="10"
                            Background="White"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1"
                            Click="OnEditClicked">

                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   Text="&#xE70F;"
                                   FontSize="18"/>
                    </Button>

                    <Button Margin="10 0"
                            Padding="10"
                            Background="Red"
                            Foreground="DarkRed"
                            BorderBrush="DarkRed"
                            BorderThickness="1"
                            Click="OnDeleteClicked">

                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   Text="&#xE74D;"
                                   FontSize="18"/>
                    </Button>

                </StackPanel>
            </Grid>

            <Button Content="Load Permissions"
                    Margin="0,20"
                    Background="#4CAF50"
                    Foreground="White"
                    Width="150"
                    Click="OnLoadClicked"/>

            <WrapPanel x:Name="PermissionsContainer"
                       HorizontalAlignment="Left"
                       Margin="0,20"/>

        </StackPanel>
    </ScrollViewer>

</Page>